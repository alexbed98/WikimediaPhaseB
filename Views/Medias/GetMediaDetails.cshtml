@model Models.Media
@{
    var connectedUser = Models.User.ConnectedUser;
    if (Model != null)
    {
        bool canView = Model.Shared || connectedUser.IsAdmin || Model.OwnerId == connectedUser.Id;
        User mediaOwner = DAL.DB.Users.Get(Model.OwnerId);
        if (canView)
        {
            <dl>
                @if (Model.Shared && (connectedUser.Id == Model.OwnerId || connectedUser.IsAdmin))
                {
                    <dd>
                        <span style="color:grey">[Partagée]</span>
                    </dd>
                }


                <dd>
                    @Model.Title
                </dd>

                <dd>
                    @Helper.YoutubePlayer(Model.YoutubeId)
                </dd>
                <dd class="description">
                    @Model.Description
                </dd>
                <dt>
                    Catégorie
                </dt>

                <dd>
                    @Model.Category
                </dd>

                <dt>
                    Date de publication
                </dt>

                <dd>
                    @Helper.When(Model.PublishDate)
                </dd>

                <dt>
                    Ajouté par
                </dt>

                <dd>
                    @Helper.AvatarUser(mediaOwner)
                </dd>

            </dl>
        }
        else
        {
            <h3 style="color: red"> Cette vidéo n'est plus partagée </h3>
        }
    }
    else
    {
        <h3 style="color: red"> La vidéo n'est plus disponible </h3>
    }
}